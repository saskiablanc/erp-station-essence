<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /public/

# Laisse passer les fichiers/dossiers existants (assets, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tout le reste vers le front controller
RewriteRule ^ index.php [L,QSA]
</IfModule>
